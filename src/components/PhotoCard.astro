---
import type { CollectionEntry } from 'astro:content';

interface Props { foto: CollectionEntry<'fotos'>; }
const { foto } = Astro.props;
const date = new Intl.DateTimeFormat('ca-ES', { dateStyle: 'long' }).format(foto.data.entorn.data);
const hasProcess = foto.data.imatges_addicionals.some((imatge) => imatge.tipus === 'process');
---

<article class="photo-card">
	<a href={`/foto/${foto.id}`} aria-label={`Veure la fitxa de ${foto.data.objecte}`}>
		<div class="photo-card__image">
			<img src={`/imagenes/${foto.data.imatge}`} alt={`Fotografia astronòmica de ${foto.data.objecte}`} loading="lazy" decoding="async" />
			{hasProcess && <span class="photo-card__process" title="Inclou el flux de processat">Procés inclòs</span>}
		</div>
		<div class="photo-card__body">
			<h2>{foto.data.objecte}</h2>
			<p><b>Constel·lació:</b> {foto.data.constellacio}</p>
			<p><b>Exposició:</b> {foto.data.exposicio.temps_total}</p>
			<p>{date}</p>
		</div>
	</a>
</article>
