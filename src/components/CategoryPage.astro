---
import type { CollectionEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import CatalogHeader from './CatalogHeader.astro';
import PhotoCard from './PhotoCard.astro';
import type { CategoryKey, Lang } from '../i18n';
import { categories, copy, languageLinks } from '../i18n';
import { photoText } from '../photoTranslations';

interface Props { lang: Lang; categoryKey: CategoryKey; fotos: CollectionEntry<'fotos'>[]; }
const { lang, categoryKey, fotos } = Astro.props;
const base = import.meta.env.BASE_URL;
const category = categories.find((item) => item.key === categoryKey)!;
const label = category.labels[lang];
const t = copy[lang];
const searchableText = (value: string) => value.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLocaleLowerCase();
---

<Layout title={label} description={t.categoryDescription(label)} minimal lang={lang} languageLinks={languageLinks.category(categoryKey, base)}>
	<section aria-labelledby="category-heading">
		<div class="catalog-controls">
			<CatalogHeader lang={lang} currentCategory={categoryKey} />
			<div class="catalog-controls__search">
				<div class="search catalog-search">
					<label class="sr-only" for="buscador">{t.search}</label>
					<div class="catalog-search__field">
						<svg aria-hidden="true" viewBox="0 0 24 24"><path d="m21 21-4.4-4.4m2.4-5.1a7.5 7.5 0 1 1-15 0 7.5 7.5 0 0 1 15 0Z" /></svg>
						<input id="buscador" type="search" placeholder={t.searchPlaceholder} autocomplete="off" />
					</div>
				</div>
				<div class="catalog-order">
					<label for="ordre">{t.order}</label>
					<select id="ordre"><option value="date">{t.recent}</option><option value="name">{t.name}</option></select>
				</div>
				<p
					class="catalog-count"
					id="recompte-fotos"
					aria-live="polite"
					data-singular={t.photographedObject}
					data-plural={t.photographedObjects}
				>{fotos.length} {fotos.length === 1 ? t.photographedObject : t.photographedObjects}</p>
			</div>
		</div>
		<div class="page-heading">
			<h1 id="category-heading">{label}</h1>
		</div>
		<div class="photo-grid" id="grid-fotos">
			{fotos.length ? fotos.map((foto) => {
				const text = photoText(foto, lang);
				const searchIndex = searchableText([foto.id, text.objecte, foto.data.constellacio, foto.data.categoria].join(' '));
				return <div data-card data-search={searchIndex} data-name={text.objecte} data-date={foto.data.entorn.data.valueOf()}><PhotoCard foto={foto} lang={lang} /></div>;
			}) : <p class="empty-state">{t.emptyCategory}</p>}
			{fotos.length > 0 && <p class="empty-state" id="sense-resultats" hidden>{t.noResults}</p>}
		</div>
	</section>
</Layout>

<script>
	const search = document.querySelector<HTMLInputElement>('#buscador');
	const order = document.querySelector<HTMLSelectElement>('#ordre');
	const grid = document.querySelector<HTMLElement>('#grid-fotos');
	const cards = [...document.querySelectorAll<HTMLElement>('[data-card]')];
	const empty = document.querySelector<HTMLElement>('#sense-resultats');
	const count = document.querySelector<HTMLElement>('#recompte-fotos');
	const collator = new Intl.Collator(document.documentElement.lang, { numeric: true, sensitivity: 'base' });
	const updateCount = (visible: number) => {
		if (!count) return;
		const countLabel = visible === 1 ? count.dataset.singular : count.dataset.plural;
		count.textContent = `${visible} ${countLabel ?? ''}`.trim();
	};
	search?.addEventListener('input', () => {
		const term = search.value.normalize('NFD').replace(/[\u0300-\u036f]/g, '').trim().toLocaleLowerCase();
		let visible = 0;
		cards.forEach((card) => {
			const matches = card.dataset.search?.includes(term) ?? false;
			card.hidden = !matches;
			if (matches) visible += 1;
		});
		if (empty) empty.hidden = visible !== 0;
		updateCount(visible);
	});
	order?.addEventListener('change', () => {
		const sorted = [...cards].sort((a, b) => order.value === 'name'
			? collator.compare(a.dataset.name ?? '', b.dataset.name ?? '')
			: Number(b.dataset.date) - Number(a.dataset.date));
		grid?.append(...sorted);
	});
</script>
