---
import Layout from '../layouts/Layout.astro';
import type { Lang } from '../i18n';
import { equipmentHref } from '../i18n';
import type { EquipmentGroupId } from '../data/equipment';
import { equipmentGroupLinks, equipmentGroups, equipmentUi, itemHref } from '../data/equipment';

interface Props { lang: Lang; groupId: EquipmentGroupId; }
const { lang, groupId } = Astro.props;
const base = import.meta.env.BASE_URL;
const group = equipmentGroups.find((candidate) => candidate.id === groupId)!;
const ui = equipmentUi[lang];
const countLabel = group.items.length === 1 ? ui.component : ui.components;
---

<Layout minimal lang={lang} title={group.title[lang]} description={group.summary[lang]} languageLinks={equipmentGroupLinks(group, base)}>
	<section class="equipment-catalog" aria-labelledby="equipment-category-heading">
		<a class="back-link" href={equipmentHref(lang, base)}>← {ui.backEquipment}</a>
		<div class="page-heading equipment-catalog__heading">
			<p class="equipment-kicker">{ui.prototype} · {group.number}</p>
			<h1 id="equipment-category-heading">{group.title[lang]}</h1>
			<p>{group.summary[lang]}</p>
			<p class="equipment-catalog__count">{group.items.length} {countLabel}</p>
		</div>
		<div class="photo-grid equipment-catalog-grid">
			{group.items.map((equipmentItem) => (
				<article class="photo-card equipment-card">
					<a href={itemHref(lang, group, equipmentItem, base)} aria-label={`${ui.viewDetails} ${equipmentItem.title[lang]}`}>
						{equipmentItem.image && equipmentItem.imageAlt ? (
							<div class:list={['equipment-image', 'equipment-card__image', { 'equipment-provisional-image': equipmentItem.imageProvisional }]} data-watermark={equipmentItem.imageProvisional ? ui.provisionalImage : undefined}>
								<img src={`${base}${equipmentItem.image}`} alt={equipmentItem.imageAlt[lang]} loading="lazy" />
							</div>
						) : (
							<div class="equipment-ghost" aria-hidden="true">
								<span class="equipment-ghost__number">{equipmentItem.number}</span>
								<span class="equipment-ghost__label">{ui.photoPending}</span>
							</div>
						)}
						<div class="photo-card__body">
							<p class="equipment-card__kicker">{equipmentItem.kicker[lang]}</p>
							<h2>{equipmentItem.title[lang]}</h2>
							<p>{equipmentItem.summary[lang]}</p>
						</div>
					</a>
				</article>
			))}
		</div>
	</section>
</Layout>
