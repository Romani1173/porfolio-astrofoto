---
import Layout from '../layouts/Layout.astro';
import type { Lang } from '../i18n';
import { copy, homeHref, languageLinks, withBase } from '../i18n';
import { equipmentGroups, equipmentUi, groupHref } from '../data/equipment';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const base = import.meta.env.BASE_URL;
const t = copy[lang];
const ui = equipmentUi[lang];
const photo = withBase('imagenes/equipo-vista-lateral-izquierda.webp', base);
---

<Layout minimal compact lang={lang} title={t.myEquipment} languageLinks={languageLinks.equipment(base)} backLink={{ href: homeHref(lang, base), label: ui.backHome }}>
	<article class="equipment-page">
		<header class="equipment-heading">
			<div class="equipment-heading__title">
				<div>
					<h1>{t.myEquipment}</h1>
				</div>
				<p class="equipment-instruction"><span aria-hidden="true">◎</span> {ui.explore}</p>
			</div>
		</header>

		<nav class="equipment-explorer equipment-explorer--landing" aria-label={ui.explore}>
			<div class="equipment-stage">
				<div class="equipment-stage__backdrop" aria-hidden="true"><img src={photo} alt="" /></div>
				<div class="equipment-stage__photo">
					<img src={photo} alt={t.myEquipment} />
					<svg class="equipment-callouts" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
						{equipmentGroups.map((group) => (
							<g class="equipment-callout" data-group-line={group.id}>
								<line x1={group.hotspot.x} y1={group.hotspot.y} x2={group.hotspot.targetX} y2={group.hotspot.targetY} vector-effect="non-scaling-stroke" />
								<circle cx={group.hotspot.targetX} cy={group.hotspot.targetY} r="0.8" vector-effect="non-scaling-stroke" />
							</g>
						))}
					</svg>
					{equipmentGroups.map((group) => (
						<div
							class="equipment-hotspot-wrapper"
							style={`--x:${group.hotspot.x}%;--y:${group.hotspot.y}%`}
							data-label-side={group.hotspot.x > 50 ? 'right' : 'left'}
						>
							<button
								type="button"
								class="equipment-hotspot equipment-hotspot--group"
								aria-label={`${group.number}. ${group.title[lang]}`}
								aria-expanded="false"
								aria-controls={`equipment-label-${group.id}`}
								data-group-trigger={group.id}
							>
								<span>{group.number}</span>
							</button>
							<a
								id={`equipment-label-${group.id}`}
								class="equipment-hotspot__label"
								href={groupHref(lang, group, base)}
								tabindex="-1"
							>{group.title[lang]}</a>
						</div>
					))}
				</div>
				<div class="equipment-stage__shade" aria-hidden="true"></div>
			</div>
		</nav>
	</article>
</Layout>

<script>
	const triggers = document.querySelectorAll<HTMLButtonElement>('[data-group-trigger]');
	let activeTrigger: HTMLButtonElement | null = null;
	const setLine = (id: string | undefined, active: boolean) => {
		if (!id) return;
		document.querySelector(`[data-group-line="${id}"]`)?.classList.toggle('is-active', active);
	};
	const clearSelection = () => {
		if (!activeTrigger) return;
		activeTrigger.closest('.equipment-hotspot-wrapper')?.classList.remove('is-active');
		activeTrigger.setAttribute('aria-expanded', 'false');
		setLine(activeTrigger.dataset.groupTrigger, false);
		activeTrigger = null;
	};
	triggers.forEach((trigger) => {
		trigger.addEventListener('click', () => {
			if (trigger === activeTrigger) return;
			clearSelection();
			trigger.closest('.equipment-hotspot-wrapper')?.classList.add('is-active');
			trigger.setAttribute('aria-expanded', 'true');
			setLine(trigger.dataset.groupTrigger, true);
			activeTrigger = trigger;
		});
	});
	document.addEventListener('pointerdown', (event) => {
		if (activeTrigger?.closest('.equipment-hotspot-wrapper')?.contains(event.target as Node)) return;
		clearSelection();
	});
</script>
