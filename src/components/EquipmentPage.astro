---
import Layout from '../layouts/Layout.astro';
import type { Lang } from '../i18n';
import { copy, homeHref, languageLinks } from '../i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const base = import.meta.env.BASE_URL;
const t = copy[lang];

const pageCopy = {
	ca: {
		back: 'Tornar a la portada',
		prototype: 'Prototip local',
		instruction: 'Explora els punts de l’equip',
		imageAlt: 'Esquema provisional de l’equip d’astrofotografia muntat',
		items: [
			{ id: 'ota', number: '01', kicker: 'Captura principal', title: 'OTA principal', specs: 'Tub òptic principal de captura', x: 54, y: 39, zoom: 1.75, originX: 55, originY: 38 },
			{ id: 'reducer', number: '02', kicker: 'Tren òptic', title: 'Reductor-aplanador', specs: 'Correcció de camp · reducció focal', x: 78, y: 41, zoom: 2.55, originX: 79, originY: 40 },
			{ id: 'filter-wheel', number: '03', kicker: 'Tren d’imatge', title: 'Roda portafiltres', specs: 'Selecció automatitzada de filtres', x: 85, y: 45, zoom: 2.65, originX: 85, originY: 41 },
			{ id: 'main-camera', number: '04', kicker: 'Captura principal', title: 'Càmera principal', specs: 'Sensor principal de captura', x: 93, y: 43, zoom: 2.75, originX: 93, originY: 41 },
			{ id: 'guide-scope', number: '05', kicker: 'Seguiment', title: 'Tub de seguiment', specs: 'Tub òptic dedicat al guiatge', x: 58, y: 25, zoom: 2.3, originX: 59, originY: 24 },
			{ id: 'guide-camera', number: '06', kicker: 'Seguiment', title: 'Càmera de seguiment', specs: 'Sensor dedicat al guiatge', x: 75, y: 27, zoom: 2.65, originX: 75, originY: 25 },
			{ id: 'power', number: '07', kicker: 'Electrònica a bord', title: 'Alimentació i escalfadors', specs: 'Distribució d’alimentació · cintes calefactores · sensor de temperatura i humitat', x: 56, y: 57, zoom: 2.45, originX: 56, originY: 56 },
			{ id: 'usb', number: '08', kicker: 'Connectivitat', title: 'Hub USB', specs: 'Connexió USB centralitzada de tots els equips', x: 66, y: 59, zoom: 2.55, originX: 66, originY: 57 },
			{ id: 'flats', number: '09', kicker: 'Calibratge', title: 'Panell de flats', specs: 'Il·luminació uniforme per a les preses de flats', x: 17, y: 69, zoom: 2.05, originX: 17, originY: 70 },
			{ id: 'capture-control', number: '10', kicker: 'Control de captura', title: 'Equip de control', specs: 'Control local del programari de captura', x: 83, y: 72, zoom: 2.15, originX: 83, originY: 71 },
		],
	},
	es: {
		back: 'Volver a la portada',
		prototype: 'Prototipo local',
		instruction: 'Explora los puntos del equipo',
		imageAlt: 'Esquema provisional del equipo de astrofotografía montado',
		items: [
			{ id: 'ota', number: '01', kicker: 'Captura principal', title: 'OTA principal', specs: 'Tubo óptico principal de captura', x: 54, y: 39, zoom: 1.75, originX: 55, originY: 38 },
			{ id: 'reducer', number: '02', kicker: 'Tren óptico', title: 'Reductor-aplanador', specs: 'Corrección de campo · reducción focal', x: 78, y: 41, zoom: 2.55, originX: 79, originY: 40 },
			{ id: 'filter-wheel', number: '03', kicker: 'Tren de imagen', title: 'Rueda portafiltros', specs: 'Selección automatizada de filtros', x: 85, y: 45, zoom: 2.65, originX: 85, originY: 41 },
			{ id: 'main-camera', number: '04', kicker: 'Captura principal', title: 'Cámara principal', specs: 'Sensor principal de captura', x: 93, y: 43, zoom: 2.75, originX: 93, originY: 41 },
			{ id: 'guide-scope', number: '05', kicker: 'Seguimiento', title: 'Tubo de seguimiento', specs: 'Tubo óptico dedicado al guiado', x: 58, y: 25, zoom: 2.3, originX: 59, originY: 24 },
			{ id: 'guide-camera', number: '06', kicker: 'Seguimiento', title: 'Cámara de seguimiento', specs: 'Sensor dedicado al guiado', x: 75, y: 27, zoom: 2.65, originX: 75, originY: 25 },
			{ id: 'power', number: '07', kicker: 'Electrónica a bordo', title: 'Alimentación y calentadores', specs: 'Distribución de alimentación · cintas calentadoras · sensor de temperatura y humedad', x: 56, y: 57, zoom: 2.45, originX: 56, originY: 56 },
			{ id: 'usb', number: '08', kicker: 'Conectividad', title: 'Hub USB', specs: 'Conexión USB centralizada de todos los equipos', x: 66, y: 59, zoom: 2.55, originX: 66, originY: 57 },
			{ id: 'flats', number: '09', kicker: 'Calibración', title: 'Panel de flats', specs: 'Iluminación uniforme para las tomas de flats', x: 17, y: 69, zoom: 2.05, originX: 17, originY: 70 },
			{ id: 'capture-control', number: '10', kicker: 'Control de captura', title: 'Equipo de control', specs: 'Control local del software de captura', x: 83, y: 72, zoom: 2.15, originX: 83, originY: 71 },
		],
	},
	en: {
		back: 'Back to the home page',
		prototype: 'Local prototype',
		instruction: 'Explore the equipment points',
		imageAlt: 'Provisional diagram of the assembled astrophotography equipment',
		items: [
			{ id: 'ota', number: '01', kicker: 'Main capture', title: 'Main OTA', specs: 'Main optical tube for image capture', x: 54, y: 39, zoom: 1.75, originX: 55, originY: 38 },
			{ id: 'reducer', number: '02', kicker: 'Optical train', title: 'Reducer-flattener', specs: 'Field correction · focal reduction', x: 78, y: 41, zoom: 2.55, originX: 79, originY: 40 },
			{ id: 'filter-wheel', number: '03', kicker: 'Imaging train', title: 'Filter wheel', specs: 'Automated filter selection', x: 85, y: 45, zoom: 2.65, originX: 85, originY: 41 },
			{ id: 'main-camera', number: '04', kicker: 'Main capture', title: 'Main camera', specs: 'Main image-capture sensor', x: 93, y: 43, zoom: 2.75, originX: 93, originY: 41 },
			{ id: 'guide-scope', number: '05', kicker: 'Tracking', title: 'Guide scope', specs: 'Dedicated optical tube for guiding', x: 58, y: 25, zoom: 2.3, originX: 59, originY: 24 },
			{ id: 'guide-camera', number: '06', kicker: 'Tracking', title: 'Guide camera', specs: 'Dedicated guiding sensor', x: 75, y: 27, zoom: 2.65, originX: 75, originY: 25 },
			{ id: 'power', number: '07', kicker: 'On-board electronics', title: 'Power and dew heaters', specs: 'Power distribution · dew heaters · temperature and humidity sensor', x: 56, y: 57, zoom: 2.45, originX: 56, originY: 56 },
			{ id: 'usb', number: '08', kicker: 'Connectivity', title: 'USB hub', specs: 'Centralised USB connection for all equipment', x: 66, y: 59, zoom: 2.55, originX: 66, originY: 57 },
			{ id: 'flats', number: '09', kicker: 'Calibration', title: 'Flat-field panel', specs: 'Uniform illumination for flat-field frames', x: 17, y: 69, zoom: 2.05, originX: 17, originY: 70 },
			{ id: 'capture-control', number: '10', kicker: 'Capture control', title: 'Control unit', specs: 'Local control of the image-capture software', x: 83, y: 72, zoom: 2.15, originX: 83, originY: 71 },
		],
	},
}[lang];

const photos = {
	left: `${base}imagenes/equipo-vista-lateral-izquierda.webp`,
	right: `${base}imagenes/equipo-vista-lateral-derecha.webp`,
	rear: `${base}imagenes/equipo-vista-posterior.webp`,
	electronics: `${base}imagenes/equipo-detalle-electronica.webp`,
	mount: `${base}imagenes/equipo-detalle-montura.webp`,
	placeholder: `${base}imagenes/equipo-placeholder.svg`,
};

const viewCopy = {
	ca: {
		left: 'Lateral esquerra', right: 'Lateral dreta', rear: 'Vista posterior', electronics: 'Detall d’electrònica', mount: 'Detall de muntura',
		alt: 'Fotografia provisional de l’equip d’astrofotografia',
	},
	es: {
		left: 'Lateral izquierda', right: 'Lateral derecha', rear: 'Vista posterior', electronics: 'Detalle de electrónica', mount: 'Detalle de montura',
		alt: 'Fotografía provisional del equipo de astrofotografía',
	},
	en: {
		left: 'Left side', right: 'Right side', rear: 'Rear view', electronics: 'Electronics detail', mount: 'Mount detail',
		alt: 'Provisional photograph of the astrophotography equipment',
	},
}[lang];

const views = [
	{ id: 'left', number: '01', label: viewCopy.left, image: photos.left, defaultItem: 'ota' },
	{ id: 'right', number: '02', label: viewCopy.right, image: photos.right, defaultItem: 'reducer' },
	{ id: 'rear', number: '03', label: viewCopy.rear, image: photos.rear, defaultItem: 'filter-wheel' },
	{ id: 'electronics', number: '04', label: viewCopy.electronics, image: photos.electronics, defaultItem: 'power' },
	{ id: 'mount', number: '05', label: viewCopy.mount, image: photos.mount, defaultItem: 'guide-scope' },
];

const visuals: Record<string, { view: string; image: string; x: number; y: number; zoom: number; originX: number; originY: number; hotspot: boolean }> = {
	ota: { view: 'left', image: photos.left, x: 34, y: 24, zoom: 1.85, originX: 34, originY: 24, hotspot: true },
	reducer: { view: 'right', image: photos.right, x: 39, y: 37, zoom: 2.2, originX: 39, originY: 37, hotspot: true },
	'filter-wheel': { view: 'rear', image: photos.rear, x: 48, y: 55, zoom: 2.3, originX: 48, originY: 55, hotspot: true },
	'main-camera': { view: 'rear', image: photos.rear, x: 56, y: 67, zoom: 2.2, originX: 56, originY: 67, hotspot: true },
	'guide-scope': { view: 'mount', image: photos.mount, x: 38, y: 9, zoom: 2.15, originX: 38, originY: 9, hotspot: true },
	'guide-camera': { view: 'mount', image: photos.mount, x: 14, y: 23, zoom: 2.35, originX: 14, originY: 23, hotspot: true },
	power: { view: 'electronics', image: photos.electronics, x: 60, y: 31, zoom: 2.25, originX: 60, originY: 31, hotspot: true },
	usb: { view: 'mount', image: photos.mount, x: 47, y: 27, zoom: 2.3, originX: 47, originY: 27, hotspot: true },
	flats: { view: 'other', image: photos.placeholder, x: 17, y: 69, zoom: 2.05, originX: 17, originY: 70, hotspot: false },
	'capture-control': { view: 'other', image: photos.placeholder, x: 83, y: 72, zoom: 2.15, originX: 83, originY: 71, hotspot: false },
};

const items = pageCopy.items.map((item) => ({ ...item, ...visuals[item.id] }));
const first = items[0];
const firstView = views[0];
const total = String(items.length).padStart(2, '0');
---

<Layout minimal lang={lang} title={t.myEquipment} languageLinks={languageLinks.equipment(base)}>
	<article class="equipment-page" data-equipment-explorer data-equipment-total={total}>
		<header class="equipment-heading">
			<a class="back-link" href={homeHref(lang, base)}>← {pageCopy.back}</a>
			<div class="equipment-heading__title">
				<div>
					<p class="equipment-kicker">{pageCopy.prototype}</p>
					<h1>{t.myEquipment}</h1>
				</div>
				<p class="equipment-instruction"><span aria-hidden="true">◎</span> {pageCopy.instruction}</p>
			</div>
		</header>

		<div class="equipment-explorer">
			<section class="equipment-stage" aria-label={pageCopy.instruction}>
				<div class="equipment-stage__backdrop" aria-hidden="true">
					<img src={firstView.image} alt="" data-equipment-stage-backdrop />
				</div>
				<div class="equipment-stage__photo">
					<img src={firstView.image} alt={`${viewCopy.alt}: ${firstView.label}`} data-equipment-stage-image />
					{items.filter((item) => item.hotspot).map((item) => (
						<button
							type="button"
							class:list={{ 'equipment-hotspot': true, 'is-active': item.id === first.id }}
							style={`--x:${item.x}%;--y:${item.y}%`}
							hidden={item.view !== firstView.id}
							aria-label={`${item.kicker}: ${item.title}`}
							aria-pressed={item.id === first.id ? 'true' : 'false'}
							data-equipment-control
							data-equipment-hotspot
							data-id={item.id}
							data-view={item.view}
							data-image={item.image}
							data-number={item.number}
							data-kicker={item.kicker}
							data-title={item.title}
							data-specs={item.specs}
							data-zoom={item.zoom}
							data-origin-x={item.originX}
							data-origin-y={item.originY}
						>
							<span>{item.number}</span>
						</button>
					))}
				</div>
				<div class="equipment-stage__shade" aria-hidden="true"></div>
				<span class="equipment-stage__counter" data-equipment-counter>{first.number} / {total}</span>
			</section>

			<aside class="equipment-inspector" aria-live="polite">
				<div class="equipment-inspector__visual">
					<img
						src={first.image}
						alt=""
						style={`--zoom:${first.zoom};--origin-x:${first.originX}%;--origin-y:${first.originY}%`}
						data-equipment-detail-image
					/>
					<span class="equipment-inspector__number" data-equipment-number>{first.number}</span>
				</div>
				<div class="equipment-inspector__copy">
					<p data-equipment-kicker>{first.kicker}</p>
					<h2 data-equipment-title>{first.title}</h2>
					<span data-equipment-specs>{first.specs}</span>
				</div>
			</aside>
		</div>

		<nav class="equipment-photo-views" aria-label={viewCopy.alt}>
			{views.map((view, index) => (
				<button
					type="button"
					class:list={{ 'equipment-photo-view': true, 'is-active': index === 0 }}
					aria-pressed={index === 0 ? 'true' : 'false'}
					data-equipment-view-control
					data-view={view.id}
					data-image={view.image}
					data-alt={`${viewCopy.alt}: ${view.label}`}
					data-default-item={view.defaultItem}
				>
					<img src={view.image} alt="" />
					<span><b>{view.number}</b> {view.label}</span>
				</button>
			))}
		</nav>

		<nav class="equipment-views" aria-label={pageCopy.instruction}>
			{items.map((item, index) => (
				<button
					type="button"
					class:list={{ 'equipment-view': true, 'is-active': index === 0 }}
					aria-pressed={index === 0 ? 'true' : 'false'}
					data-equipment-control
					data-id={item.id}
					data-view={item.view}
					data-image={item.image}
					data-number={item.number}
					data-kicker={item.kicker}
					data-title={item.title}
					data-specs={item.specs}
					data-zoom={item.zoom}
					data-origin-x={item.originX}
					data-origin-y={item.originY}
				>
					<span class="equipment-view__image">
						<img src={item.image} alt="" style={`--zoom:${item.zoom};--origin-x:${item.originX}%;--origin-y:${item.originY}%`} />
					</span>
					<span class="equipment-view__label"><b>{item.number}</b> {item.title}</span>
				</button>
			))}
		</nav>
	</article>
</Layout>

<script>
	const explorers = document.querySelectorAll<HTMLElement>('[data-equipment-explorer]');

	explorers.forEach((explorer) => {
		const controls = explorer.querySelectorAll<HTMLButtonElement>('[data-equipment-control]');
		const hotspots = explorer.querySelectorAll<HTMLButtonElement>('[data-equipment-hotspot]');
		const viewControls = explorer.querySelectorAll<HTMLButtonElement>('[data-equipment-view-control]');
		const stageImage = explorer.querySelector<HTMLImageElement>('[data-equipment-stage-image]');
		const stageBackdrop = explorer.querySelector<HTMLImageElement>('[data-equipment-stage-backdrop]');
		const detailImage = explorer.querySelector<HTMLImageElement>('[data-equipment-detail-image]');
		const number = explorer.querySelector<HTMLElement>('[data-equipment-number]');
		const counter = explorer.querySelector<HTMLElement>('[data-equipment-counter]');
		const kicker = explorer.querySelector<HTMLElement>('[data-equipment-kicker]');
		const title = explorer.querySelector<HTMLElement>('[data-equipment-title]');
		const specs = explorer.querySelector<HTMLElement>('[data-equipment-specs]');
		const total = explorer.dataset.equipmentTotal ?? '00';

		const showView = (viewId: string) => {
			const selectedView = Array.from(viewControls).find((item) => item.dataset.view === viewId);
			if (!selectedView) return;
			viewControls.forEach((item) => {
				const active = item === selectedView;
				item.classList.toggle('is-active', active);
				item.setAttribute('aria-pressed', String(active));
			});
			hotspots.forEach((item) => { item.hidden = item.dataset.view !== viewId; });
			if (stageImage) {
				stageImage.src = selectedView.dataset.image ?? stageImage.src;
				stageImage.alt = selectedView.dataset.alt ?? '';
			}
			if (stageBackdrop) stageBackdrop.src = selectedView.dataset.image ?? stageBackdrop.src;
		};

		const activate = (control: HTMLButtonElement) => {
			const data = control.dataset;
			if (data.view && data.view !== 'other') showView(data.view);
			controls.forEach((item) => {
				const active = item.dataset.id === data.id;
				item.classList.toggle('is-active', active);
				item.setAttribute('aria-pressed', String(active));
			});
			if (detailImage) {
				detailImage.src = data.image ?? detailImage.src;
				detailImage.style.setProperty('--zoom', data.zoom ?? '1');
				detailImage.style.setProperty('--origin-x', `${data.originX ?? 50}%`);
				detailImage.style.setProperty('--origin-y', `${data.originY ?? 50}%`);
			}
			if (number) number.textContent = data.number ?? '';
			if (counter) counter.textContent = `${data.number ?? ''} / ${total}`;
			if (kicker) kicker.textContent = data.kicker ?? '';
			if (title) title.textContent = data.title ?? '';
			if (specs) specs.textContent = data.specs ?? '';
		};

		controls.forEach((control) => {
			control.addEventListener('click', () => activate(control));
			control.addEventListener('focus', () => activate(control));
			control.addEventListener('pointerenter', () => activate(control));
		});

		viewControls.forEach((viewControl) => {
			const selectView = () => {
				showView(viewControl.dataset.view ?? '');
				const defaultItem = Array.from(controls).find((item) => item.dataset.id === viewControl.dataset.defaultItem);
				if (defaultItem) activate(defaultItem);
			};
			viewControl.addEventListener('click', selectView);
			viewControl.addEventListener('focus', selectView);
		});
	});
</script>
