---
import Layout from '../layouts/Layout.astro';
import type { Lang } from '../i18n';
import type { EquipmentGroupId, EquipmentItemId } from '../data/equipment';
import { equipmentGroups, equipmentItemLinks, equipmentUi, groupHref } from '../data/equipment';

interface Props { lang: Lang; groupId: EquipmentGroupId; itemId: EquipmentItemId; }
const { lang, groupId, itemId } = Astro.props;
const base = import.meta.env.BASE_URL;
const group = equipmentGroups.find((candidate) => candidate.id === groupId)!;
const equipmentItem = group.items.find((candidate) => candidate.id === itemId)!;
const ui = equipmentUi[lang];
---

<Layout minimal lang={lang} title={equipmentItem.title[lang]} description={equipmentItem.summary[lang]} languageLinks={equipmentItemLinks(group, equipmentItem, base)}>
	<article class="equipment-detail">
		<a class="back-link" href={groupHref(lang, group, base)}>← {group.title[lang]}</a>
		<header class="equipment-detail__heading">
			<p class="equipment-kicker">{group.number}.{equipmentItem.number} · {ui.provisional}</p>
			<h1>{equipmentItem.title[lang]}</h1>
			<p>{equipmentItem.summary[lang]}</p>
		</header>
		{equipmentItem.image && equipmentItem.imageAlt ? (
			<figure class:list={['equipment-image', 'equipment-detail__image', { 'equipment-provisional-image': equipmentItem.imageProvisional }]} data-watermark={equipmentItem.imageProvisional ? ui.provisionalImage : undefined}>
				<img src={`${base}${equipmentItem.image}`} alt={equipmentItem.imageAlt[lang]} />
			</figure>
		) : (
			<div class="equipment-ghost equipment-ghost--detail" aria-label={ui.photoPending}>
				<span class="equipment-ghost__number">{equipmentItem.number}</span>
				<span class="equipment-ghost__label">{ui.photoPending}</span>
			</div>
		)}
		{equipmentItem.description || equipmentItem.notes || equipmentItem.specs ? (
			<div class="equipment-detail__content">
				{equipmentItem.description && <p class="equipment-detail__description">{equipmentItem.description[lang]}</p>}
				{equipmentItem.notes?.map((note) => (
					<section class="equipment-detail__note">
						<h2>{note.title[lang]}</h2>
						<p>{note.body[lang]}</p>
					</section>
				))}
				{equipmentItem.specs ? (
					<section class="equipment-specifications" aria-labelledby="equipment-specifications-heading">
						<p class="equipment-kicker">{equipmentItem.kicker[lang]}</p>
						<h2 id="equipment-specifications-heading">{ui.specifications}</h2>
						<dl>
							{equipmentItem.specs.map((spec) => (
								<div>
									<dt>{spec.label[lang]}</dt>
									<dd>{spec.value[lang]}</dd>
								</div>
							))}
						</dl>
					</section>
				) : (
					<section class="equipment-detail__pending">
						<p>{equipmentItem.kicker[lang]}</p>
						<h2>{ui.detailsPending}</h2>
					</section>
				)}
			</div>
		) : (
			<section class="equipment-detail__pending">
				<p>{equipmentItem.kicker[lang]}</p>
				<h2>{ui.detailsPending}</h2>
			</section>
		)}
		{equipmentItem.additionalImage && equipmentItem.additionalImageAlt && (
			<figure class="equipment-reference-graphic">
				<div class:list={['equipment-image', { 'equipment-provisional-image': equipmentItem.additionalImageProvisional }]} data-watermark={equipmentItem.additionalImageProvisional ? ui.provisionalImage : undefined}>
					<img src={`${base}${equipmentItem.additionalImage}`} alt={equipmentItem.additionalImageAlt[lang]} loading="lazy" />
				</div>
				<figcaption>{equipmentItem.additionalImageCaption?.[lang] ?? ui.referenceGraphic}</figcaption>
			</figure>
		)}
		{equipmentItem.galleryImages?.map((galleryImage) => (
			<figure class="equipment-reference-graphic">
				<div class="equipment-image">
					<img src={`${base}${galleryImage.image}`} alt={galleryImage.alt[lang]} loading="lazy" />
				</div>
				<figcaption>{galleryImage.caption[lang]}</figcaption>
			</figure>
		))}
	</article>
</Layout>
