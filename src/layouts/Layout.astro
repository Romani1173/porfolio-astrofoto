---
import '../styles/global.css';
import { SITE_TITLE } from '../consts';
import LanguageSelector from '../components/LanguageSelector.astro';
import type { Lang } from '../i18n';
import { copy, galleryHref, homeHref, languageLinks as makeLanguageLinks, normalizeBase, withBase } from '../i18n';

interface Props {
	title?: string;
	description?: string;
	hero?: boolean;
	minimal?: boolean;
	compact?: boolean;
	lang?: Lang;
	languageLinks?: Record<Lang, string>;
	backLink?: { href: string; label: string };
}
const { title = SITE_TITLE, hero = false, minimal = false, compact = false, lang = 'ca', languageLinks = makeLanguageLinks.home(import.meta.env.BASE_URL), backLink } = Astro.props;
const description = Astro.props.description ?? copy[lang].siteDescription;
const pageTitle = title === SITE_TITLE ? SITE_TITLE : `${title} | ${SITE_TITLE}`;
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL;
const rootHref = normalizeBase(base);
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const nav = [
	{ href: homeHref(lang, base), label: copy[lang].home },
	{ href: galleryHref(lang, base), label: copy[lang].catalogue },
];
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#080b12" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Space+Mono&display=swap" rel="stylesheet" />
		<link rel="icon" type="image/svg+xml" href={withBase('favicon.svg', base)} />
		<link rel="icon" href={withBase('favicon.ico', base)} />
		<link rel="canonical" href={canonicalURL} />
		{Object.entries(languageLinks).map(([language, href]) => <link rel="alternate" hreflang={language} href={new URL(href, Astro.site)} />)}
		<link rel="alternate" hreflang="x-default" href={new URL(languageLinks.ca, Astro.site)} />
		<title>{pageTitle}</title>
	</head>
	<body class:list={{ 'home-page': hero, 'equipment-section': compact }}>
		{!minimal && !hero && <header class:list={{ 'site-header': true, 'site-shell': true, 'site-header--compact': hero }}>
			{hero ? <a class="site-brand" href={rootHref}>{SITE_TITLE}</a> : <><h1 class="site-title"><a href={rootHref}>{SITE_TITLE}</a></h1><p class="site-tagline">{SITE_DESCRIPTION}</p></>}
			{!hero && <nav class="site-nav" aria-label="Navegació principal">
				{nav.map((item) => <a href={item.href} aria-current={currentPath === decodeURIComponent(item.href) ? 'page' : undefined}>{item.label}</a>)}
			</nav>}
		</header>}
		<div class:list={{ 'language-selector-shell': true, 'language-selector-shell--hero': hero, 'language-selector-shell--with-back': Boolean(backLink), 'language-selector-shell--compact': compact, 'site-shell': !hero }}>
			{backLink && <a class="back-link back-link--toolbar" href={backLink.href}>← {backLink.label}</a>}
			<LanguageSelector lang={lang} links={languageLinks} />
		</div>
		<main class:list={{ 'site-shell': true, 'home-main': hero, 'minimal-main': minimal, 'compact-main': compact }}><slot /></main>
		<footer class="site-footer site-shell">© {new Date().getFullYear()} {SITE_TITLE}</footer>
	</body>
</html>
