---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PhotoCard from '../../components/PhotoCard.astro';

export async function getStaticPaths() {
	const fotos = await getCollection('fotos');
	const categories = ['Galàxies', 'Nebuloses', 'Cúmuls i Estrelles', 'Cel'];
	return categories.map((categoria) => ({ params: { categoria } }));
}

const { categoria } = Astro.params;
const fotos = (await getCollection('fotos'))
	.filter((foto) => foto.data.categoria === categoria)
	.sort((a, b) => b.data.entorn.data.valueOf() - a.data.entorn.data.valueOf());
const base = import.meta.env.BASE_URL;
const categories = [
	{ name: 'Galàxies', href: 'Gal%C3%A0xies' },
	{ name: 'Nebuloses', href: 'Nebuloses' },
	{ name: 'Cúmuls i Estrelles', label: 'Cúmuls i estrelles', href: 'C%C3%BAmuls%20i%20Estrelles' },
	{ name: 'Cel', href: 'Cel' },
];
---

<Layout title={categoria} description={`Fotografies de ${categoria.toLocaleLowerCase()} del meu catàleg de cel profund.`} minimal>
	<section aria-labelledby="category-heading">
		<div class="catalog-controls">
			<div class="catalog-controls__top">
				<a class="catalog-home" href={`${base}galeria`}>← Tornar al catàleg</a>
				<nav class="catalog-category-nav" aria-label="Filtra per categoria">
					<a href={`${base}galeria`}>Tots</a>
					{categories.map((category) => (
						<a
							href={`${base}categoria/${category.href}`}
							aria-current={category.name === categoria ? 'page' : undefined}
						>
							{category.label ?? category.name}
						</a>
					))}
				</nav>
			</div>
		</div>
		<div class="page-heading">
			<h1 id="category-heading">{categoria}</h1>
			<div class="category-toolbar">
				<div class="catalog-order">
					<label for="ordre">Ordena</label>
					<select id="ordre">
						<option value="date">Data: recents</option>
						<option value="name">Nom: A–Z</option>
					</select>
				</div>
				<p class="catalog-count">{fotos.length} {fotos.length === 1 ? 'objecte fotografiat' : 'objectes fotografiats'}</p>
			</div>
		</div>
		<div class="photo-grid" id="grid-fotos">
			{fotos.length ? fotos.map((foto) => <div data-card data-name={foto.data.objecte} data-date={foto.data.entorn.data.valueOf()}><PhotoCard foto={foto} /></div>) : <p class="empty-state">Encara no hi ha cap fotografia en aquesta categoria.</p>}
		</div>
	</section>
</Layout>

<script>
	const order = document.querySelector<HTMLSelectElement>('#ordre');
	const grid = document.querySelector<HTMLElement>('#grid-fotos');
	const cards = [...document.querySelectorAll<HTMLElement>('[data-card]')];
	const collator = new Intl.Collator('ca', { numeric: true, sensitivity: 'base' });

	order?.addEventListener('change', () => {
		const sorted = [...cards].sort((a, b) => order.value === 'name'
			? collator.compare(a.dataset.name ?? '', b.dataset.name ?? '')
			: Number(b.dataset.date) - Number(a.dataset.date));
		grid?.append(...sorted);
	});
</script>
