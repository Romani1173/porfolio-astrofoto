---
import { getCollection } from 'astro:content';
import CategoryPage from '../../../components/CategoryPage.astro';
import { categories } from '../../../i18n';

export async function getStaticPaths() {
	const fotos = await getCollection('fotos');
	return categories.map((category) => ({
		params: { category: category.slugs.en },
		props: { categoryKey: category.key, fotos: fotos.filter((foto) => foto.data.categoria === category.value).sort((a, b) => b.data.entorn.data.valueOf() - a.data.entorn.data.valueOf()) },
	}));
}
const { categoryKey, fotos } = Astro.props;
---

<CategoryPage lang="en" categoryKey={categoryKey} fotos={fotos} />
