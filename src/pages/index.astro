---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;
---

<Layout title="Inici" hero>
	<section class="welcome-hero" style={`--hero-image: url('${base}imagenes/portada.webp')`} aria-labelledby="welcome-title">
		<div class="welcome-hero__content">
			<h1 id="welcome-title">El meu Cel Profund</h1>
			<p class="welcome-hero__description">Un recull personal de fotografies de cel profund.</p>
			<a class="welcome-hero__cta" href={`${base}galeria`}>Explora el catàleg <span aria-hidden="true">→</span></a>
		</div>
	</section>
</Layout>
